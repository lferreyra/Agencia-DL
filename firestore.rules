rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields: uid, email, displayName, photoURL, createdAt
    //
    // Collection: /users/{userId}/sessions/{sessionId}
    // Fields: userId, title, updatedAt
    //
    // Collection: /users/{userId}/sessions/{sessionId}/messages/{messageId}
    // Fields: role, content, timestamp, hasFile
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string;
    }

    function isValidSession(data, userId) {
      return data.updatedAt != null;
    }

    function isValidMessage(data) {
      return data.role in ['user', 'assistant'] &&
             data.content is string;
    }

    // Rules
    match /__test__/{docId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /sessions/{sessionId} {
        allow read, delete: if isOwner(userId);
        allow write: if isOwner(userId) && isValidSession(request.resource.data, userId);
        
        match /messages/{messageId} {
          allow read: if isOwner(userId);
          allow write: if isOwner(userId) && isValidMessage(request.resource.data);
        }
      }
    }
  }
}
