rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields: uid, email, displayName, photoURL, createdAt
    //
    // Collection: /users/{userId}/sessions/{sessionId}
    // Fields: userId, title, updatedAt
    //
    // Collection: /users/{userId}/sessions/{sessionId}/messages/{messageId}
    // Fields: role, content, timestamp, hasFile
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string;
    }

    function isValidSession(data, userId) {
      return data.keys().hasAll(['userId', 'updatedAt']) &&
             data.userId == userId;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'timestamp']) &&
             data.role in ['user', 'assistant'] &&
             data.content is string;
    }

    // Rules
    match /users/{userId} {
      allow read, write: if isOwner(userId) && (request.method == 'GET' || isValidUser(request.resource.data));
      
      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId) && (request.method == 'GET' || request.method == 'DELETE' || isValidSession(request.resource.data, userId));
        
        match /messages/{messageId} {
          allow read, write: if isOwner(userId) && (request.method == 'GET' || isValidMessage(request.resource.data));
        }
      }
    }
  }
}
